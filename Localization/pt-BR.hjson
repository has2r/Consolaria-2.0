		Configs: {
			ConsolariaConfig: {
				DisplayName: Configuração

				Headers: {
					SeasonalEvents: Eventos Sazonais
					Miscellaneous: Outros
					WorldGeneration: Geração de Mundo
				}

				easterEnabled: {
					Label: Restringir conteúdo sazonal por data do sistema (Páscoa)
					Tooltip:
						'''
						Se ativado, os itens e inimigos relevantes só aparecerão durante a Páscoa
						1 de abril - 30 de abril
						'''
				}

				thanksgivingEnabled: {
					Label: Restringir conteúdo sazonal por data do sistema (Ação de Graças)
					Tooltip:
						'''
						Se ativado, os itens e inimigos relevantes só aparecerão durante o Dia de Ação de Graças
						1 de novembro - 30 de novembro
						'''
				}

				smallEventsEnabled: {
					Label: Restringir conteúdo sazonal por data do sistema (outros eventos)
					Tooltip: Se ativado, os itens e inimigos relevantes só aparecerão durante os feriados correspondentes ou quando a Fúrcula for usada
				}

				vanillaBossMusicEnabled: {
					Label: Música Padrão para os chefes de Consolaria
					Tooltip: Se ativado, a trilha sonora personalizada será substituída por temas originalmente usados ​​nas versões de console
				}

				tizonaZenithIntegrationEnabled: {
					Label: Integração da Tizona na Zênite
					Tooltip: Se ativado, a Tizona será adicionada à receita de fabricação da Zênite e aos seus projéteis.
				}

				oktoberLocksEnabled: {
					Label: Item Decorativo de Cachos Oktober
					Tooltip: Se ativado, os Cachos da Oktober estarão disponíveis para compra com o Alfaiate durante a Oktoberfest
				}

				mythicalWyvernKiteVanillaDropruleEnabled: {
					Label: Regra de Drop Padrão para a Pipa de Serpezinha Mítica
					Tooltip: Se ativado, a Pipa de Serpe Mítica terá 4% de chance de ser obtido da Serpe Mítica durante os Dias Ventosos, em vez de ser obtido no Envelope Vermelho
				}

				heartbeatariaIntegrationEnabled: {
					Label: Integração do Mod Heartbeataria
					Tooltip: Se ativado, itens exclusivos do Mod Heartbeataria podem ser obtidos no Red Envelope
				}

				originalAncientHeroSetRecipeEnabled: {
					Label: Receita original do conjunto do Herói Antigo
					Tooltip: Se ativado, o conjunto do Herói Antigo pode ser criado usando Seda e Fio Roxo em um Tear em vez do Shimmer
				}

				genderRestrictShopEnabled: {
					Label: Restringir o conjunto de George e o conjunto Fabuloso por gênero do jogador
					Tooltip:
						'''
						Se ativado, os conjuntos relevantes só aparecerão na loja do Alfaiate durante uma Lua de Sangue se o jogador tiver um determinado gênero
						Masculino - conjunto de George
						Feminino - Conjunto Fabuloso
						'''
				}

				pyramidEnabled: {
					Label: Pirâmide garantida
					Tooltip: Se habilitado, pelo menos 1 pirâmide sempre será gerada no mundo
				}

				pyramidMessageLoot: {
					Label: Saque de pirâmide especial
					Tooltip: Se habilitado, uma mensagem especial aparecerá no baú da segunda sala da pirâmide
				}
			}
		}

