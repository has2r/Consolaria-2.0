			ArchWyvernTail.DisplayName: Архививерна
			BigEgg.DisplayName: Яйцо Лепуса
			ChocolateEgg.DisplayName: Шоколадное яйцо

			DisasterBunny: {
				DisplayName: Пасхальный заяц
				Bestiary: Чудовищное порождение гигантского кролика. Эти пучеглазые создания кусают всё, что встречается на их пути.
			}

			Lepus: {
				DisplayName: Лепус
				Bestiary: Как будто его размеров было недостаточно, этот кролик способен размножаться с помощью разноцветных яиц, которые весной разлетаются по всему миру, а глупцы, в свою очередь, могут их подобрать.

				BossChecklistIntegration: {
					SpawnInfo: Используйте [i:Consolaria/SuspiciousLookingEgg]
					DespawnMessage: Лепус упрыгивает в рассвет!
				}
			}

			SmallEgg.DisplayName: Яйцо Лепуса

			Ocram: {
				DisplayName: Окрам
				Bestiary: Этот забытый, отравленный демон однажды был императором тьмы. Теперь он ищет мести против всех жителей поверхности.

				BossChecklistIntegration: {
					SpawnInfo: Используйте [i:5643] ночью
					DespawnMessage: Окрам исчезает обратно в тень!
				}
			}

			ServantofOcram: {
				DisplayName: Прислужник Окрама
				Bestiary: Порождения зла, служащие Окраму, были созданы чтобы защищать своего хозяина любой ценой.
			}

			TurkorNeck.DisplayName: Шея Туркора

			TurkortheUngrateful: {
				DisplayName: Туркор Неблагодарный
				Bestiary: Это чудовище, существующее на чистой злобе, ежегодно проводит вендетту против тех, кто осмеливается откусить кусочек индейки на День благодарения.

				BossChecklistIntegration: {
					EntryName: Туркор Неблагодарный
					SpawnInfo: Используйте [i:5641] когда за вами следует Индейка
					DespawnMessage: Туркор Неблагодарный сбегает с обеденной тарелки!
				}
			}

			TurkortheUngratefulHead.DisplayName: Голова Туркора Неблагодарного

			DragonHornet: {
				DisplayName: Драконий шершень
				Bestiary: Являясь родственниками обычных шершней, эти сменили свой облик, чтобы отпугивать врагов. Если же этого недостаточно, то их ядовитые жала должны сработать.
			}

			DragonSkull: {
				DisplayName: Драконий череп
				Bestiary: Затронутые некромантическими заклинаниями, головы древних рептилий теперь охотятся на живых, разделяя проклятие со своими жертвами
			}

			DragonSnatcher: {
