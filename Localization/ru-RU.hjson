				thanksgivingEnabled: {
					Label: Ограничить сезонный контент по системной дате (День Благодарения)
					Tooltip:
						'''
						При включении соответствующие предметы и враги будут появляться только в День Благодарения
						1 Ноября - 30 Ноября
						'''
				}

				smallEventsEnabled: {
					Label: Ограничить сезонный контент по системной дате (Другие события)
					Tooltip: При включении определенные предметы и враги будут появляться только в соответствующие праздники, или после использования Кости Желаний
				}

				vanillaBossMusicEnabled: {
					Label: Включить ванильную музыку для боссов из Consolaria
					Tooltip: При включении музыкальные треки из мода будут заменены на те, которые были изначально использованы в консольных версиях
				}

				tizonaZenithIntegrationEnabled: {
					Label: Интеграция Тизоны в Зенит
					Tooltip: При включении Тизона будет использована в рецепте создания Зенита и появится среди его снарядов
				}

				oktoberLocksEnabled: {
					Label: Декоративный предмет - Прическа Октоберфеста
					Tooltip: При включении Прическа Октоберфеста будет продаваться Портным во время Октоберфеста
				}

				mythicalWyvernKiteVanillaDropruleEnabled: {
					Label: Ванильное правило выпадения Воздушного змея «Мифическая Виверна»
					Tooltip: При включении Воздушный змей «Мифическая Виверна» будет выпадать из Мифической Виверны с 4%-ным шансом, вместо Красного конверта
				}

				heartbeatariaIntegrationEnabled: {
					Label: Интеграция мода Heartbeataria
					Tooltip: При включении некоторые предметы из Heartbeataria можно получить из Красных конвертов
				}

				originalAncientHeroSetRecipeEnabled: {
					Label: Изначальный рецепт создания Древнего набора Героя
					Tooltip: При включении Древний набор Героя может быть создан из Шелка и Фиолетовой нитки на Ткацком станке вместо шиммера
				}

				genderRestrictShopEnabled: {
					Label: Ограничить покупку набора Джорджа и Потрясающего набора по полу персонажа
					Tooltip:
						'''
						При включении Портной будет продавать эти наборы во время Кровавой луны только если у персонажа определенный пол
