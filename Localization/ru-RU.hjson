			ConsolariaConfig: {
				DisplayName: Конфигурация

				Headers: {
					SeasonalEvents: Сезонные события
					Miscellaneous: Разное
					WorldGeneration: Создание мира
				}

				easterEnabled: {
					Label: Ограничить сезонный контент по системной дате (Пасха)
