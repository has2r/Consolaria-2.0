					Чрезмерное использование этого оружия изматывает вас, значительно снижая его урон 
					Убийство восстанавливает часть изматывания 
					'''
			}

			JadeSeal: {
				DisplayName: Нефритовая печать
				Tooltip:
					'''
					При нажатии ЛКМ призывает нефритовую лампу, которая увеличивает урон и защиту всех союзников внутри её ауры 
					При нажатии ПКМ призывает золоту лампу, которая парит на месте и исцеляет всех союзников внутри её ауры 
					'''
			}

			Omunikodo: {
				DisplayName: Омуникодо
				Tooltip: Выпускает волну хаотичных звуков
			}

			PortableSpecialCorn: {
				DisplayName: Портативная особая кукуруза
				Tooltip: Повторяет каждую четвертую симфоническую атаку, нанося 50% урона
			}

			UtensilPoker: {
				DisplayName: Кухонный протыкатель
				Tooltip:
					'''
					При нажатии ПКМ приготавливает до 5 метательных вилок 
					Вилки застревают во врагах, вызывая кровотечение 
					Чрезмерное использование этого оружия изматывает вас, значительно снижая его урон
					Убийство восстанавливает часть изматывания
					'''
			}

			Chocoplotion: {
				DisplayName: Шоковзрыв
				Tooltip:
					'''
					Прыгает в сторону врага и разрывается шоколадными кусочками Hops towards an enemy and explodes into chocolate droplets
					Чрезмерное использование изматывает вас, значительно снижая его урон
					Убийство восстанавливает часть изматывания
					'''
			}

			FiveStarBuffet: {
				DisplayName: Пятизвёздочный буфет
				Tooltip: Приготавливает до 5 сочных блюд, после чего кормит ими союзников с наименьшим количеством здоровья
			}

			AlbinoSwarmerBanner: {
				DisplayName: Знамя роевика-альбиноса
				// Tooltip: "{$CommonItemTooltip.BannerBonus}Albino Swarmer"
			}

			BleachCanister: {
				DisplayName: Банка с отбеливателем
				Tooltip: Призывает альбиноса-недоростка
			}
		}

		NPCs: {
			AlbinoAntlion: {
				DisplayName: Муравьиный лев-альбинос
				Bestiary: Вид муравьиных львов с редкой мутацией, проявляющий большую агрессивность, возможно, чтобы компенсировать чувствительность к солнечному свету.
			}

			AlbinoCharger: {
				DisplayName: Муравьиный воитель-альбинос
				Bestiary: Иногда муравьиные воители мутируют, теряя свою окраску и становясь более свирепыми, чем их собратья по рою.
			}

			ArchDemon: {
				DisplayName: Архидемон
				Bestiary: Особенно сильные демоны живут так долго, что их тела превращаются в иссушенную оболочку.
			}

			ArchWyvernHead: {
				DisplayName: Архививерна
				Bestiary: Легенды гласят, что виверны способны извергать огонь. Но они умалчивают, что лишь немногие из них доживают до возраста, когда могут обрести такую ​​силу.
			}

